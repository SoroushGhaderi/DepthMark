{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Orbit Signal",
  "type": "object",
  "required": [
    "signal_id",
    "status",
    "entity",
    "family",
    "subfamily",
    "grain",
    "row_identity",
    "asset_paths",
    "frontmatter",
    "source_path",
    "markdown_body",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "signal_id": {
      "type": "string",
      "minLength": 3
    },
    "status": {
      "type": "string",
      "enum": ["active", "draft", "deprecated"]
    },
    "entity": {
      "type": "string"
    },
    "family": {
      "type": "string"
    },
    "subfamily": {
      "type": "string"
    },
    "grain": {
      "type": "string"
    },
    "headline": {
      "type": ["string", "null"]
    },
    "trigger": {
      "type": ["string", "null"]
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "row_identity": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "asset_paths": {
      "type": "object",
      "additionalProperties": true
    },
    "frontmatter": {
      "type": "object",
      "additionalProperties": true
    },
    "source_path": {
      "type": "string",
      "minLength": 1
    },
    "markdown_body": {
      "type": "string"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": true
}
