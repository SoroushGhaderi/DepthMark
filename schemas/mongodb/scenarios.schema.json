{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Orbit Scenario",
  "type": "object",
  "required": [
    "scenario_id",
    "name",
    "status",
    "markdown_body",
    "channels",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "scenario_id": {
      "type": "string",
      "minLength": 3
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["active", "draft", "deprecated"]
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "channels": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "signal_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "markdown_body": {
      "type": "string"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": true
}

