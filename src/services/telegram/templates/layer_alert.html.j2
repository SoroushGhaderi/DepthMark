{% set layer_emoji = {"bronze": "🥉", "silver": "🥈", "gold": "🥇", "quality": "🔍"} %}
{% set status_emoji = "✅" if data.success else "❌" %}
<b>{{ status_emoji }} {{ layer_emoji.get(data.layer, "📦") }} {{ data.layer | capitalize }}</b> · {{ data.scope }} · {{ format_duration(data.duration_seconds) }}
{% if data.details %}{% for key, value in data.details.items() %}{{ key }}: <b>{{ value }}</b>{% if not loop.last %} · {% endif %}{% endfor %}{% endif %}
{% if data.entity_coverage %}<b>📋 Coverage</b>
{% for entity in data.entity_coverage %}{{ entity.name }}: {{ entity.bronze }}→{{ entity.silver }} ({{ "%.0f"|format(entity.coverage) }}%){% if not loop.last %}
{% endif %}{% endfor %}
Missing: {{ data.missing_count }} · Avg: {{ "%.0f"|format(data.avg_coverage) }}% · Min: {{ "%.0f"|format(data.min_coverage) }}%
{% endif %}{% if data.insights %}<b>💡</b> {% for key, value in data.insights.items() %}{{ key }}: <b>{{ value }}</b>{% if not loop.last %} · {% endif %}{% endfor %}
{% endif %}{% if data.success %}✅ Done.
{% else %}⚠️ Issues detected.
{% endif %}