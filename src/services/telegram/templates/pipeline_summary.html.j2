{% set status_emoji = "✅" if data.success else "⚠️" %}
<b>{{ status_emoji }} Pipeline</b> · {{ data.date }} · {{ format_duration(data.total_duration_seconds) }}
{% for step in data.steps %}{{ step.status_icon }} {{ step.name }} · {{ format_duration(step.duration_seconds) }}{% if not step.success and step.error %} · <i>{{ step.error[:60] }}</i>{% endif %}
{% endfor %}Dates: {{ data.dates_processed }}/{{ data.dates_total }}
{% if data.success %}✅ All steps completed.
{% else %}{% for step in data.steps %}{% if not step.success %}❌ {{ step.name }} failed.
{% endif %}{% endfor %}{% endif %}